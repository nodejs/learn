{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "out",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/learn",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/learn/_vercel/(.*)",
      "destination": "https://node-learn-pages.vercel.app/_vercel/$1"
    }
  ]
}
